features:
  # 邮箱更改配置
  emailChange:
    enabled: true
    config:
      requirePasswordVerification: true

  # 手机号更改配置
  phoneChange:
    enabled: false
    config:
      requirePasswordVerification: true

  # 用户名更改配置
  usernameChange:
    enabled: false
    config:
      requirePasswordVerification: true

  # MFA 配置
  mfa:
    totp:
      enabled: true
    backupCodes:
      enabled: true
    webAuthn:
      enabled: true

  # Passkey 配置
  passkey:
    enabled: true

  # 社交账号连接
  socialIdentities:
    enabled: true
    config:
      # connectors 为唯一配置来源：启用状态、展示信息、connectorId 都在这里管理
      connectors:
        - target: google
          connectorId: logto_google_connector_id
          enabled: false
          displayName: Google
          icon: google
          description: 绑定 Google 账号
        - target: github
          connectorId: logto_github_connector_id
          enabled: true
          displayName: GitHub
          icon: github
          description: 绑定 GitHub 账号
        - target: qq
          connectorId: logto_qq_connector_id
          enabled: true
          displayName: QQ
          icon: qq
          description: 绑定 QQ 账号

  # 会话管理
  sessions:
    enabled: true

  # 账户删除
  accountDeletion:
    enabled: true
    config:
      requirePasswordConfirmation: true
      requireConfirmationText: true

profileFields:
  avatar:
    enabled: true
    label: 头像
    description: 您的个人头像
    placeholder: https://example.com/avatar.jpg
    inputType: url

  name:
    enabled: true
    label: 显示名称
    description: 您的公开显示名称
    placeholder: 输入您的姓名
    inputType: text
    required: true

  birthdate:
    enabled: false
    label: 出生日期
    description: 您的生日信息
    inputType: date

  zoneinfo:
    enabled: false
    label: 时区
    description: 您所在的时区
    placeholder: Asia/Shanghai
    inputType: text

  locale:
    enabled: false
    label: 语言
    description: 界面语言偏好
    placeholder: zh-CN
    inputType: text

  website:
    enabled: false
    label: 个人网站
    description: 您的个人主页链接
    placeholder: https://example.com
    inputType: url
