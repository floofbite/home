features:
  emailChange:
    enabled: true
    config:
      requirePasswordVerification: true

  phoneChange:
    enabled: false
    config:
      requirePasswordVerification: true

  usernameChange:
    enabled: false
    config:
      requirePasswordVerification: true

  mfa:
    totp:
      enabled: true
    backupCodes:
      enabled: true
    webAuthn:
      enabled: true

  passkey:
    enabled: true

  socialIdentities:
    enabled: true
    config:
      connectors:
        - target: google
          connectorId: logto_google_connector_id
          enabled: false
          displayName: Google
          icon: google
          description: 绑定 Google 账号
        - target: github
          connectorId: logto_github_connector_id
          enabled: true
          displayName: GitHub
          icon: github
          description: 绑定 GitHub 账号
        - target: qq
          connectorId: logto_qq_connector_id
          enabled: true
          displayName: QQ
          icon: qq
          description: 绑定 QQ 账号

  sessions:
    enabled: true

  accountDeletion:
    enabled: true
    config:
      requirePasswordConfirmation: true
      requireConfirmationText: true

profileFields:
  avatar:
    enabled: true
    label: 头像
    description: 您的个人头像
    placeholder: https://example.com/avatar.jpg
    inputType: url

  name:
    enabled: true
    label: 显示名称
    description: 您的公开显示名称
    placeholder: 输入您的姓名
    inputType: text
    required: true

  birthdate:
    enabled: false
    label: 出生日期
    description: 您的生日信息
    inputType: date

  zoneinfo:
    enabled: false
    label: 时区
    description: 您所在的时区
    placeholder: Asia/Shanghai
    inputType: text

  locale:
    enabled: false
    label: 语言
    description: 界面语言偏好
    placeholder: zh-CN
    inputType: text

  website:
    enabled: false
    label: 个人网站
    description: 您的个人主页链接
    placeholder: https://example.com
    inputType: url
