# Runtime environment
NODE_ENV=production

# App network
HOSTNAME=0.0.0.0
PORT=3000

# Logto endpoint (e.g. https://your-tenant.logto.app)
LOGTO_ENDPOINT=

# Third-party app (Traditional Web) credentials
LOGTO_APP_ID=
LOGTO_APP_SECRET=

# Cookie encryption secret (at least 32 characters)
LOGTO_COOKIE_SECRET=

# Public base URLs
BASE_URL_PROD=
BASE_URL_DEV=

# Machine-to-Machine app credentials
LOGTO_M2M_CLIENT_ID=
LOGTO_M2M_CLIENT_SECRET=

# Optional social callback override
SOCIAL_BINDING_CALLBACK_BASE_URL=
