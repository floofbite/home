# Logto endpoint (e.g. https://your-tenant.logto.app)
LOGTO_ENDPOINT=

# Third-party app (Traditional Web) credentials
LOGTO_APP_ID=
LOGTO_APP_SECRET=

# Node runtime mode (usually production in Docker)
NODE_ENV=production

# Public base URLs used by app/logto.ts
BASE_URL_PROD=
BASE_URL_DEV=

# Optional: force social-binding callback base URL
# When set, social redirect_uri will be:
# {SOCIAL_BINDING_CALLBACK_BASE_URL}/dashboard/connections/social/callback?target=...
SOCIAL_BINDING_CALLBACK_BASE_URL=

# Cookie encryption secret (at least 32 characters)
LOGTO_COOKIE_SECRET=

# Machine-to-Machine app credentials (for Management API)
LOGTO_M2M_CLIENT_ID=
LOGTO_M2M_CLIENT_SECRET=

# Social connectors are now configured in config/source/features.yaml (features.socialIdentities.config.connectors)
# Keep these envs empty unless you still have old custom logic depending on them.
# LOGTO_GITHUB_CONNECTOR_ID=
# LOGTO_GOOGLE_CONNECTOR_ID=
# LOGTO_AVAILABLE_CONNECTORS=

# Optional app display name
APP_NAME="Account Center"

# Portal settings
PORTAL_ENABLED=true
PORTAL_TITLE="服务门户"

# Runtime config directory (used in Docker/runtime mode)
# CONFIG_DIR=/app/runtime-config
